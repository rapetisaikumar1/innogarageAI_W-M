{
  "name": "innogarage-ai",
  "version": "1.0.0",
  "description": "AI-Powered Interview Assistant Desktop Application",
  "main": "./out/main/index.js",
  "engines": {
    "node": ">=20"
  },
  "author": "innogarage.ai",
  "homepage": "https://innogarage.ai",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "server": "tsx src/server/index.ts",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/server/db/migrate.ts",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "electron-vite build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac && codesign --deep --force --sign - dist/mac-arm64/innogarage.ai.app",
    "install:mac": "rm -rf /Applications/innogarage.ai.app && ditto dist/mac-arm64/innogarage.ai.app /Applications/innogarage.ai.app && xattr -cr /Applications/innogarage.ai.app && echo 'Installed. Open from /Applications/'",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@deepgram/sdk": "^3.9.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/websocket": "^11.2.0",
    "@google/generative-ai": "^0.24.1",
    "@neondatabase/serverless": "^1.0.2",
    "@sendgrid/mail": "^8.1.6",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.4",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.8.0",
    "mammoth": "^1.12.0",
    "nodemailer": "^8.0.5",
    "pdf-parse": "^2.4.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.0",
    "tsx": "^4.21.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.1",
    "@types/nodemailer": "^8.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.31.10",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "postcss": "^8.5.9",
    "prettier": "^3.7.4",
    "puppeteer": "^24.40.0",
    "rcedit": "^5.0.2",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
